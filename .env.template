# AI Provider API Keys
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Admin
# Leave blank for normal local development. `next dev` treats the seeded
# test@test.com Appwrite user as an admin without granting that in production.
ADMIN_ID=
NEXT_PUBLIC_ADMIN_ID=

# Local Postgres
# `npm run db:up` starts this database through Docker.
DATABASE_URL="postgresql://calvinist_parrot:calvinist_parrot@localhost:54322/calvinist_parrot_dev?schema=public"
SHADOW_DATABASE_URL="postgresql://calvinist_parrot:calvinist_parrot@localhost:54322/calvinist_parrot_shadow?schema=public"
TEST_DATABASE_URL="postgresql://calvinist_parrot:calvinist_parrot@localhost:54322/calvinist_parrot_test?schema=public"

# CCEL remains a separate PGVector store from the app database.
# Use a read-only dev/staging connection, or seed a local copy before pointing here.
CCEL_URL=

# Appwrite
APPWRITE_ENDPOINT=https://appwrite.calvinistparrot.com/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APP_URL=http://localhost:3000
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://appwrite.calvinistparrot.com/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=

# Variable for multiple features
FT_MODEL=
PARROT_AGENT_PROVIDER=gemini
PARROT_OPENAI_MODEL=gpt-5-mini
PARROT_GEMINI_MODEL=gemini-3-flash-preview
KIDS_LARGER_MODEL_MIN_WORDS=200
JOURNAL_LARGER_MODEL_MIN_WORDS=250
STUDY_BIBLE_MCP_URL=https://studybible-mcp.fly.dev/sse
NOMINATIM_USER_AGENT=CalvinistParrotChurchFinder/1.0 (contact@calvinistparrot.local)

